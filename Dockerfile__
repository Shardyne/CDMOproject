# Combined reproducible STS environment
FROM python:3.11-slim

# Avoid Python parallelism
ENV OMP_NUM_THREADS=1
ENV MKL_NUM_THREADS=1
ENV OPENBLAS_NUM_THREADS=1
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    wget \
    unzip \
    ca-certificates \
    coinor-cbc \
    glpk-utils \
    libglpk40 \
    libc6 \
    libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

# Install PuLP and numpy
RUN pip install --no-cache-dir pulp numpy z3-solver

ARG CVC5_VER=1.3.0
RUN set -eux; \
    apt-get update && apt-get install -y --no-install-recommends wget unzip ca-certificates file; \
    rm -rf /var/lib/apt/lists/*; \
    CVC5_FLAVOR="Linux-x86_64-static"; \
    wget -q -O /tmp/cvc5.zip "https://github.com/cvc5/cvc5/releases/download/cvc5-${CVC5_VER}/cvc5-${CVC5_FLAVOR}.zip"; \
    mkdir -p /opt/cvc5; \
    unzip -q /tmp/cvc5.zip -d /opt/cvc5; \
    rm -f /tmp/cvc5.zip; \
    BIN_PATH="$(find /opt/cvc5 -type f -name cvc5 -perm /111 | head -n1)"; \
    if [ -z "$BIN_PATH" ]; then echo "cvc5 binary not found after unzip!" && exit 1; fi; \
    chmod +x "$BIN_PATH"; \
    ln -sf "$BIN_PATH" /usr/local/bin/cvc5; \
    echo "[cvc5] installed binary at $BIN_PATH"; \
    cvc5 --version

